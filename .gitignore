# SvelteKit specific build and generated files
.svelte-kit/
build/

# Package manager dependencies
node_modules/

# Local environment variables and secrets
.env
.env.local
.env.*.local
!.env.example

# Production builds and outputs
dist/

# Log files
Lines starting with # are comments.
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Rust build artifacts
target/
src-tauri/target/
# Tauri generated schemas/permissions
src-tauri/gen/

# Local WhatsApp session databases (created at runtime)
*.db
*.db-shm
*.db-wal

# Editor and OS-specific files
.DS_Store
