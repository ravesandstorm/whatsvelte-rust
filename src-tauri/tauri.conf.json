{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "whatsvelte-rust",
  "version": "0.2.2",
  "identifier": "com.ravesandstorm.whatsvelte-rust",
  "build": {
    "beforeDevCommand": { "script": "npm run dev", "cwd": "../svelte-frontend" },
    "beforeBuildCommand": { "script": "npm run build", "cwd": "../svelte-frontend" },
    "devUrl": "http://localhost:5173",
    "frontendDist": "../svelte-frontend/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Wha.rs.app",
        "width": 1100,
        "height": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/media/**", "$APPLOCALDATA/media/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
